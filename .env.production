# 线上环境
VITE_USER_NODE_ENV = production

# 公共基础路径
VITE_PUBLIC_PATH = ./

# 路由模式
# Optional: hash | history
VITE_ROUTER_MODE = hash

# 是否启用 gzip 或 brotli 压缩打包，如果需要多个压缩规则，可以使用 “,” 分隔
# Optional: gzip | brotli | none
VITE_BUILD_COMPRESS = none

# 打包压缩后是否删除源文件
VITE_BUILD_COMPRESS_DELETE_ORIGIN_FILE = false

# 打包时是否删除 console
VITE_DROP_CONSOLE = true

# 是否开启 VitePWA
VITE_PWA = true

# 线上环境接口地址
VITE_API_URL = ${BASE_API}
VITE_APP_BASE_FILE = ${FILE_API}
VITE_APP_FOOD_URL = ${FOOD_API}
VITE_API_HOME_URL = "https://api.iwipwedabay.com/api/rain/iwip"
# VITE_API_URL = /intplatform-stage-api
# VITE_PROXY = [["/image","http://192.168.90.30/static/intplatform"],["/intplatform-stage-api","http://192.168.90.40/api/intplatform/app"]]
VITE_MAP_TILES_URL = "http://web.iwipwedabay.com/static/parkride/iwip-map/"
VITE_MAP_TILES_URL_https = "https://web.iwipwedabay.com/static/parkride/iwip-map/"
VITE_WEB_SOCKET_URL = "wss://api.iwipwedabay.com/api/intplatform/mis/customer/websocket/"
VITE_ALARM_WS_URL = "wss://api.iwipwedabay.com/api/security/mis/websocket/customer-service/"
