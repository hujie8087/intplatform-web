# 本地环境
VITE_USER_NODE_ENV = development

# 公共基础路径
VITE_PUBLIC_PATH = ./

# 路由模式
# Optional: hash | history
VITE_ROUTER_MODE = hash

# 打包时是否删除 console
VITE_DROP_CONSOLE = true

# 是否开启 VitePWA
VITE_PWA = false

# 开发环境接口地址
VITE_API_URL = /intplatform-stage-api
# VITE_APP_BASE_FILE = http://192.168.90.30/static/intplatform
# VITE_APP_BASE_FILE = http://192.168.91.50:9000/intplatform
VITE_APP_BASE_FILE = https://web.iwipwedabay.com/static/
VITE_APP_FOOD_URL = https://web.iwipwedabay.com/static/

# 开发环境跨域代理，支持配置多个
# VITE_PROXY = [["/image","http://192.168.91.50:9000/intplatform/image"],["/intplatform-stage-api","http://192.168.91.50:10200"]]
# VITE_PROXY = [["/image","http://192.168.90.30/static/image"],["/intplatform-stage-api","http://192.168.90.40/api/intplatform/mis/"]]
# VITE_PROXY = [["/intplatform-stage-api","http://192.168.90.40/api/intplatform/mis/"]]
# VITE_PROXY = [["/image","http://192.168.91.50:9000/intplatform/image"]]
VITE_PROXY = [["/intplatform-stage-api","http://10.40.10.18:10200"]]
